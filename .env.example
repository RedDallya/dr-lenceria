# Render usa PORT automáticamente. En local podés usar 3000.
PORT=3000
NODE_ENV=production

# Seguridad
JWT_SECRET=cambiar_esta_clave_por_una_muy_larga
ADMIN_USER=admin
ADMIN_PASS=1234

# Supabase PostgreSQL
# En Supabase: Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres.xxxxx:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase Storage
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=pegar_service_role_key
SUPABASE_BUCKET=product-images
